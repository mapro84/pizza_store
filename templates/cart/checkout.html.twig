{% extends 'base.html.twig' %}

{% block title %}Commande - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4"><i class="bi bi-credit-card"></i> Finaliser la commande</h1>
    
    <div class="row">
        <div class="col-lg-8">
            {% if is_logged_in %}
            <div class="alert alert-success mb-4">
                <i class="bi bi-check-circle"></i>
                <strong>Bienvenue {{ app.user.username }}</strong> - Vos informations sont pré-remplies.
            </div>
            {% endif %}
            
            {% if app.session.get('password_errors') %}
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>{{ 'cart.create_account.password_weak'|trans }}</strong>
                <ul class="mb-0 mt-2">
                    {% for error in app.session.get('password_errors') %}
                    <li>{{ error|trans }}</li>
                    {% endfor %}
                </ul>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endif %}
            
            <form method="POST" action="{{ path('app_checkout_process') }}" id="checkoutForm">
                <div class="card mb-4">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0"><i class="bi bi-person"></i> Informations de livraison</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="firstName" class="form-label">Prénom *</label>
                                <input type="text" class="form-control" id="firstName" name="firstName" value="{{ prefilled.firstName|default('') }}" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="lastName" class="form-label">Nom *</label>
                                <input type="text" class="form-control" id="lastName" name="lastName" value="{{ prefilled.lastName|default('') }}" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label">Email (votre identifiant de connexion) *</label>
                            <input type="email" class="form-control" id="email" name="email" value="{{ prefilled.email }}" {% if is_logged_in %}readonly{% endif %} required>
                            <small class="text-muted">Cet email sera votre identifiant pour vous connecter</small>
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label">Téléphone *</label>
                            <input type="tel" class="form-control" id="phone" name="phone" value="{{ prefilled.phone }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="address" class="form-label">Adresse de livraison *</label>
                            <textarea class="form-control" id="address" name="address" rows="3" required>{{ prefilled.address }}</textarea>
                        </div>
                        
                        {% if not is_logged_in %}
                        <div class="alert border-warning">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="create_account" name="create_account" value="1">
                                <label class="form-check-label" for="create_account">
                                    <strong>Créer un compte client</strong>
                                    <small class="d-block text-muted">Gagnez des points de fidélité et suivez vos commandes !</small>
                                </label>
                            </div>
                            <div id="passwordFields" style="display: none;">
                                <div class="mt-3">
                                    <label for="username" class="form-label">Nom d'utilisateur (alias) *</label>
                                    <input type="text" class="form-control" id="username" name="username" placeholder="Votre pseudo">
                                    <small class="text-muted">Ce nom s'affichera sur vos commandes</small>
                                </div>
                                <div class="mt-3">
                                    <label for="password" class="form-label">Mot de passe *</label>
                                    <input type="password" class="form-control" id="password" name="password" placeholder="Votre mot de passe" minlength="8">
                                    <div class="alert alert-info mt-2 mb-0">
                                        <small><strong>{{ 'password.requirements'|trans }}</strong></small>
                                        <ul class="mb-0 mt-1 small" id="passwordRequirements">
                                            <li id="reqLength"><span class="text-danger">✗</span> {{ 'password.error.min_length'|trans }}</li>
                                            <li id="reqUpper"><span class="text-danger">✗</span> {{ 'password.error.uppercase'|trans }}</li>
                                            <li id="reqNumber"><span class="text-danger">✗</span> {{ 'password.error.number'|trans }}</li>
                                            <li id="reqSpecial"><span class="text-danger">✗</span> {{ 'password.error.special'|trans }}</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <label for="password_confirm" class="form-label">Confirmer le mot de passe</label>
                                    <input type="password" class="form-control" id="password_confirm" name="password_confirm" placeholder="Confirmez votre mot de passe" minlength="8">
                                    <small class="text-danger d-none" id="passwordMatchError">Les mots de passe ne correspondent pas</small>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0"><i class="bi bi-wallet2"></i> Mode de paiement</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-check payment-option" onclick="selectPayment('carte')">
                                    <input class="form-check-input" type="radio" name="payment_method" id="card" value="carte">
                                    <label class="form-check-label w-100" for="card">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-credit-card-2-front fs-3 me-3 text-danger"></i>
                                            <div>
                                                <strong>Carte bancaire</strong>
                                                <small class="d-block text-muted">Visa, Mastercard, CB <span class="badge bg-warning text-dark">Test</span></small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check payment-option" onclick="selectPayment('especes')">
                                    <input class="form-check-input" type="radio" name="payment_method" id="cash" value="especes">
                                    <label class="form-check-label w-100" for="cash">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-cash-stack fs-3 me-3 text-danger"></i>
                                            <div>
                                                <strong>Espèces</strong>
                                                <small class="d-block text-muted">Paiement à la livraison</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check payment-option" onclick="selectPayment('paypal')">
                                    <input class="form-check-input" type="radio" name="payment_method" id="paypal" value="paypal">
                                    <label class="form-check-label w-100" for="paypal">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-paypal fs-3 me-3 text-danger"></i>
                                            <div>
                                                <strong>PayPal</strong>
                                                <small class="d-block text-muted">Paiement sécurisé en ligne</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check payment-option" onclick="selectPayment('swish')">
                                    <input class="form-check-input" type="radio" name="payment_method" id="swish" value="swish">
                                    <label class="form-check-label w-100" for="swish">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-phone fs-3 me-3 text-danger"></i>
                                            <div>
                                                <strong>Swish</strong>
                                                <small class="d-block text-muted">Paiement mobile</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-danger btn-lg w-100" id="submitBtn">
                    <i class="bi bi-check-circle"></i> <span id="submitText">Confirmer la commande</span>
                </button>
            </form>
        </div>
        
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Votre commande</h5>
                </div>
                <div class="card-body">
                    {% for item in cart %}
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ item.name }} ({{ item.size }}) x{{ item.quantity }}</span>
                        <span>{{ (item.price * item.quantity)|number_format(2, ',', ' ') }} €</span>
                    </div>
                    {% endfor %}
                    <hr>
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total</span>
                        <span class="text-danger">{{ total|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <small class="text-muted d-block mt-2">
                        <i class="bi bi-clock"></i> Livraison estimée: 30-45 min
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let selectedPayment = null;

function selectPayment(method) {
    selectedPayment = method;
    document.getElementById('card').checked = method === 'carte';
    document.getElementById('cash').checked = method === 'especes';
    document.getElementById('paypal').checked = method === 'paypal';
    document.getElementById('swish').checked = method === 'swish';
}

function validatePassword(password) {
    const hasLength = password.length >= 8;
    const hasUpper = /[A-Z]/.test(password);
    const hasNumber = /[0-9]/.test(password);
    const hasSpecial = /[!@#$%^&*(),.?":{}|<>]/.test(password);
    
    document.getElementById('reqLength').innerHTML = hasLength ? '<span class="text-success">✓</span> {{ 'password.error.min_length'|trans }}' : '<span class="text-danger">✗</span> {{ 'password.error.min_length'|trans }}';
    document.getElementById('reqUpper').innerHTML = hasUpper ? '<span class="text-success">✓</span> {{ 'password.error.uppercase'|trans }}' : '<span class="text-danger">✗</span> {{ 'password.error.uppercase'|trans }}';
    document.getElementById('reqNumber').innerHTML = hasNumber ? '<span class="text-success">✓</span> {{ 'password.error.number'|trans }}' : '<span class="text-danger">✗</span> {{ 'password.error.number'|trans }}';
    document.getElementById('reqSpecial').innerHTML = hasSpecial ? '<span class="text-success">✓</span> {{ 'password.error.special'|trans }}' : '<span class="text-danger">✗</span> {{ 'password.error.special'|trans }}';
    
    return hasLength && hasUpper && hasNumber && hasSpecial;
}

function checkPasswordMatch() {
    const password = document.getElementById('password').value;
    const confirm = document.getElementById('password_confirm').value;
    const error = document.getElementById('passwordMatchError');
    
    if (confirm && password !== confirm) {
        error.classList.remove('d-none');
    } else {
        error.classList.add('d-none');
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const createAccountCheckbox = document.getElementById('create_account');
    if (createAccountCheckbox) {
        createAccountCheckbox.addEventListener('change', function() {
            document.getElementById('passwordFields').style.display = this.checked ? 'block' : 'none';
        });
    }
    
    const passwordInput = document.getElementById('password');
    if (passwordInput) {
        passwordInput.addEventListener('input', function() {
            validatePassword(this.value);
        });
    }
    
    const confirmInput = document.getElementById('password_confirm');
    if (confirmInput) {
        confirmInput.addEventListener('input', checkPasswordMatch);
    }
});

document.getElementById('checkoutForm').addEventListener('submit', function(e) {
    {% if not is_logged_in %}
    const createAccountCheckbox = document.getElementById('create_account');
    if (createAccountCheckbox && createAccountCheckbox.checked) {
        var password = document.getElementById('password').value;
        var passwordConfirm = document.getElementById('password_confirm').value;
        
        if (!validatePassword(password)) {
            e.preventDefault();
            alert('Votre mot de passe n\'est pas assez sécurisé. Veuillez respecter toutes les exigences.');
            return;
        }
        
        if (password !== passwordConfirm) {
            e.preventDefault();
            alert('Les mots de passe ne correspondent pas');
            return;
        }
    }
    {% endif %}
    
    var payment = selectedPayment || 'especes';
    
    if (payment === 'carte') {
        e.preventDefault();
        document.getElementById('submitText').textContent = 'Redirection vers le paiement...';
        document.getElementById('submitBtn').disabled = true;
        window.location.href = '{{ path('app_payment_test') }}';
    }
});
</script>

<style>
.payment-option {
    padding: 15px;
    border: 2px solid #dee2e6;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s;
}
.payment-option:hover {
    border-color: #dc3545;
}
.payment-option input:checked + label {
    color: inherit;
}
.payment-option input:checked ~ div,
.payment-option:has(input:checked) {
    border-color: #dc3545;
    background-color: #fff5f5;
}
</style>
{% endblock %}
