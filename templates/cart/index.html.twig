{% extends 'base.html.twig' %}

{% block title %}Panier - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4"><i class="bi bi-cart3"></i> Votre Panier</h1>
    
    {% if cart is empty %}
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-cart-x fs-1"></i>
            <h3 class="mt-3">Votre panier est vide</h3>
            <p class="text-muted">Découvrez nos pizzas délicieux !</p>
            <a href="{{ path('app_pizza_index') }}" class="btn btn-danger mt-3">Voir le menu</a>
        </div>
    {% else %}
        <div class="row">
            <div class="col-lg-8">
                {% for key, item in cart %}
                <div class="card mb-3">
                    <div class="row g-0">
                        <div class="col-md-3">
                            <img src="{{ item.image }}" class="img-fluid rounded-start h-100" style="object-fit: cover;" alt="{{ item.name }}">
                        </div>
                        <div class="col-md-6">
                            <div class="card-body">
                                <h5 class="card-title">{{ item.name }}</h5>
                                <p class="text-muted">
                                    Taille: 
                                    <span class="badge bg-secondary">
                                        {% if item.size == 'petite' %}Petite
                                        {% elseif item.size == 'moyenne' %}Moyenne
                                        {% else %}Grande{% endif %}
                                    </span>
                                </p>
                                <p class="price">{{ item.price|number_format(2, ',', ' ') }} €</p>
                            </div>
                        </div>
                        <div class="col-md-3 d-flex align-items-center justify-content-center">
                            <div class="d-flex align-items-center gap-2">
                                <a href="{{ path('app_cart_update', {key: key, quantity: item.quantity - 1}) }}" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-dash"></i>
                                </a>
                                <span class="fs-4 fw-bold">{{ item.quantity }}</span>
                                <a href="{{ path('app_cart_update', {key: key, quantity: item.quantity + 1}) }}" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-plus"></i>
                                </a>
                                <a href="{{ path('app_cart_remove', {key: key}) }}" class="btn btn-danger btn-sm ms-2">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            <div class="col-lg-4">
                {% if is_granted('ROLE_USER') and customer and customer.loyaltyPoints > 0 %}
                <div class="card mb-3 border-warning">
                    <div class="card-body bg-light">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-star-fill text-warning me-2"></i>
                                <strong>Points de fidélité</strong>
                            </div>
                            <span class="badge bg-warning text-dark fs-6">{{ customer.loyaltyPoints }} pts</span>
                        </div>
                        <p class="text-muted small mb-2">1 point = 1€ de réduction</p>
                        {% if app.session.get('loyalty_used', false) %}
                            <span class="badge bg-success"><i class="bi bi-check"></i> Réduction appliquée</span>
                        {% else %}
                            <form action="{{ path('app_cart_use_loyalty') }}" method="POST">
                                <button type="submit" class="btn btn-sm btn-warning w-100" 
                                        {{ total < customer.loyaltyPoints ? 'disabled' : '' }}>
                                    Utiliser mes points
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Récapitulatif</h5>
                        <hr>
                        {% for key, item in cart %}
                        <div class="d-flex justify-content-between mb-2">
                            <span>{{ item.name }} x{{ item.quantity }}</span>
                            <span>{{ (item.price * item.quantity)|number_format(2, ',', ' ') }} €</span>
                        </div>
                        {% endfor %}
                        {% if app.session.get('loyalty_discount', 0) > 0 %}
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Réduction fidélité</span>
                            <span>-{{ app.session.get('loyalty_discount', 0)|number_format(2, ',', ' ') }} €</span>
                        </div>
                        {% endif %}
                        <hr>
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span class="text-danger">{{ (total - (app.session.get('loyalty_discount', 0)))|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <a href="{{ path('app_checkout') }}" class="btn btn-danger btn-lg w-100 mt-4">
                            <i class="bi bi-credit-card"></i> Commander
                        </a>
                        <a href="{{ path('app_pizza_index') }}" class="btn btn-outline-secondary w-100 mt-2">
                            Continuer vos achats
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<style>
.price { color: #dc3545; font-weight: bold; }
</style>
{% endblock %}
