{% extends 'base.html.twig' %}

{% block title %}Commande {{ order.orderNumber }} - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_account') }}">Mon compte</a></li>
            <li class="breadcrumb-item active">Commande {{ order.orderNumber }}</li>
        </ol>
    </nav>

    <div class="card shadow">
        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-receipt me-2"></i>Commande {{ order.orderNumber }}</h4>
            <span class="badge bg-light text-dark fs-6">{{ order.orderedAt|date('d/m/Y à H:i') }}</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-4">
                    <h6 class="text-muted">Statut</h6>
                    <span class="badge {{ order.statusBadgeClass }} fs-6">{{ order.statusLabel }}</span>
                </div>
                <div class="col-md-4">
                    <h6 class="text-muted">Mode de paiement</h6>
                    <p class="mb-0">{{ order.paymentMethodLabel }}</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-muted">Contact</h6>
                    <p class="mb-0">{{ order.customerName }}</p>
                    <small class="text-muted">{{ order.customerEmail }}</small>
                </div>
            </div>

            {% if order.deliveryAddress %}
            <hr>
            <div class="row mb-4">
                <div class="col-12">
                    <h6 class="text-muted"><i class="bi bi-truck me-2"></i>Adresse de livraison</h6>
                    <p class="mb-0">{{ order.deliveryAddress }}</p>
                    <p class="mb-0">{{ order.deliveryZipCode }} {{ order.deliveryCity }}</p>
                    {% if order.deliveryNotes %}
                    <small class="text-muted"><em>Note: {{ order.deliveryNotes }}</em></small>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            <hr>

            <h5 class="mb-3">Détail de la commande</h5>
            {% if orderItems|length > 0 %}
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th class="text-center">Quantité</th>
                            <th class="text-end">Prix unitaire</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in orderItems %}
                        <tr>
                            <td>{{ item.pizzaName|default('Pizza') }}</td>
                            <td class="text-center">{{ item.quantity }}</td>
                            <td class="text-end">{{ item.unitPrice|number_format(2, ',', ' ') }} €</td>
                            <td class="text-end">{{ item.totalPrice|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Sous-total:</strong></td>
                            <td class="text-end">{{ (order.totalAmount + order.discountAmount|default(0))|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% if order.discountAmount and order.discountAmount > 0 %}
                        <tr class="text-success">
                            <td colspan="3" class="text-end">Réduction:</td>
                            <td class="text-end">-{{ order.discountAmount|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% endif %}
                        <tr>
                            <td colspan="3" class="text-end"><strong>Total:</strong></td>
                            <td class="text-end"><strong>{{ order.totalAmount|number_format(2, ',', ' ') }} €</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            {% else %}
            <p class="text-muted">Aucun détail disponible pour cette commande.</p>
            {% endif %}

            <hr>

            <div class="d-flex justify-content-between align-items-center">
                <a href="{{ path('app_account') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Retour à mon compte
                </a>
                <a href="{{ path('app_pizza_index') }}" class="btn btn-danger">
                    <i class="bi bi-cart-plus me-2"></i>Commander à nouveau
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
