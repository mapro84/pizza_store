{% extends 'base.html.twig' %}

{% block title %}{{ 'account.change_password'|trans }} - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_account') }}">{{ 'nav.my_account'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ 'account.change_password'|trans }}</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-3">
            <div class="list-group mb-4">
                <a href="{{ path('app_account') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-house me-2"></i>{{ 'nav.my_account'|trans }}
                </a>
                <a href="{{ path('app_account_profile') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-person me-2"></i>{{ 'account.profile'|trans }}
                </a>
                <a href="{{ path('app_account_orders') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-receipt me-2"></i>{{ 'nav.my_orders'|trans }}
                </a>
                <a href="{{ path('app_account_edit') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-pencil me-2"></i>{{ 'account.edit'|trans }}
                </a>
                <a href="{{ path('app_account_password') }}" class="list-group-item list-group-item-action active">
                    <i class="bi bi-key me-2"></i>{{ 'account.change_password'|trans }}
                </a>
            </div>
        </div>
        
        <div class="col-md-9">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-key me-2"></i>{{ 'account.change_password'|trans }}</h4>
                </div>
                <div class="card-body">
                    {% for flash in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle me-2"></i>{{ flash }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {% endfor %}
                    
                    {% for flash in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-triangle me-2"></i>{{ flash|trans }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {% endfor %}

                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle me-2"></i><strong>{{ 'password.requirements'|trans }}</strong>
                        <ul class="mb-0 mt-2">
                            <li>{{ 'password.requirement.min_length'|trans({'%count%': 8}) }}</li>
                            <li>{{ 'password.requirement.uppercase'|trans }}</li>
                            <li>{{ 'password.requirement.number'|trans }}</li>
                            <li>{{ 'password.requirement.special'|trans }}</li>
                        </ul>
                    </div>

                    <form method="post">
                        <div class="mb-4">
                            <label for="current_password" class="form-label">{{ 'account.current_password'|trans }}</label>
                            <input type="password" class="form-control" id="current_password" name="current_password" required>
                        </div>

                        <hr class="my-4">

                        <div class="mb-3">
                            <label for="new_password" class="form-label">{{ 'account.new_password'|trans }}</label>
                            <input type="password" class="form-control" id="new_password" name="new_password" 
                                   minlength="8" required>
                        </div>

                        <div class="mb-4">
                            <label for="confirm_password" class="form-label">{{ 'account.confirm_password'|trans }}</label>
                            <input type="password" class="form-control" id="confirm_password" name="confirm_password" 
                                   minlength="8" required>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_account_profile') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>{{ 'account.cancel'|trans }}
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-check-lg me-2"></i>{{ 'account.save_password'|trans }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
