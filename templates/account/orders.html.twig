{% extends 'base.html.twig' %}

{% block title %}{{ 'nav.my_orders'|trans }} - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_account') }}">{{ 'nav.my_account'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ 'nav.my_orders'|trans }}</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-3">
            <div class="list-group mb-4">
                <a href="{{ path('app_account') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-house me-2"></i>{{ 'nav.my_account'|trans }}
                </a>
                <a href="{{ path('app_account_profile') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-person me-2"></i>{{ 'account.profile'|trans }}
                </a>
                <a href="{{ path('app_account_orders') }}" class="list-group-item list-group-item-action active">
                    <i class="bi bi-receipt me-2"></i>{{ 'nav.my_orders'|trans }}
                </a>
                <a href="{{ path('app_account_edit') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-pencil me-2"></i>{{ 'account.edit'|trans }}
                </a>
                <a href="{{ path('app_account_password') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-key me-2"></i>{{ 'account.change_password'|trans }}
                </a>
            </div>
            
            <div class="card bg-warning text-dark mb-4">
                <div class="card-body text-center">
                    <i class="bi bi-star-fill fs-1 mb-2"></i>
                    <h3 class="mb-0">{{ loyalty_points }}</h3>
                    <small>{{ 'account.loyalty_points'|trans }}</small>
                </div>
            </div>
            
            <div class="card bg-light">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-3">{{ 'account.loyalty_program'|trans }}</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ 'account.total_orders'|trans }}:</span>
                        <strong>{{ total_orders }}</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>{{ 'account.total_spent'|trans }}:</span>
                        <strong>{{ total_spent|number_format(2, ',', ' ') }} €</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>{{ 'account.cumulative_points'|trans }}:</span>
                        <strong class="text-warning">{{ cumulative_points }}</strong>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-9">
            <div class="card shadow">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-receipt me-2"></i>{{ 'nav.my_orders'|trans }}</h4>
                    <span class="badge bg-light text-dark">{{ total_orders }} {{ 'account.orders'|trans|lower }}</span>
                </div>
                <div class="card-body">
                    {% if orders|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>{{ 'account.order_number'|trans }}</th>
                                    <th>{{ 'account.date'|trans }}</th>
                                    <th>{{ 'account.amount'|trans }}</th>
                                    <th>{{ 'account.payment_method'|trans }}</th>
                                    <th>{{ 'account.status'|trans }}</th>
                                    <th class="text-center">{{ 'account.action'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for order in orders %}
                                <tr>
                                    <td>
                                        <strong>{{ order.orderNumber }}</strong>
                                    </td>
                                    <td>{{ order.orderedAt|date('d/m/Y H:i') }}</td>
                                    <td class="fw-bold">{{ order.totalAmount|number_format(2, ',', ' ') }} €</td>
                                    <td>
                                        {% if order.paymentMethod == 'carte' %}
                                            <i class="bi bi-credit-card-2-front me-1"></i>
                                        {% elseif order.paymentMethod == 'especes' %}
                                            <i class="bi bi-cash-stack me-1"></i>
                                        {% elseif order.paymentMethod == 'paypal' %}
                                            <i class="bi bi-paypal me-1"></i>
                                        {% elseif order.paymentMethod == 'swish' %}
                                            <i class="bi bi-phone me-1"></i>
                                        {% endif %}
                                        {{ order.paymentMethodLabel }}
                                    </td>
                                    <td>
                                        <span class="badge {{ order.statusBadgeClass }}">
                                            {{ order.statusLabel }}
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a href="{{ path('app_account_order', {id: order.id}) }}" class="btn btn-sm btn-outline-danger" title="{{ 'account.view'|trans }}">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-bag text-muted fs-1"></i>
                        <p class="text-muted mt-3">{{ 'account.no_orders'|trans }}</p>
                        <a href="{{ path('app_pizza_index') }}" class="btn btn-danger">
                            <i class="bi bi-cart-plus me-2"></i>{{ 'account.order_again'|trans }}
                        </a>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
