<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
      Article
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>
  <body>
    <div class="container mt-4">
      <h1>
        Add an Article
      </h1>
      <form method="post">
        <input type="text" name="newarticle" placeholder="Article Name" type="number" class="form-control mb-2" min="1" max="9999" required>

        <button type="submit">
          Add an article
        </button>
      </form>
      {% if newarticle %}
        <p>
          Article :
          {{ newarticle }}
        </p>
      {% endif %}
    </div>
  </body>
</html>
