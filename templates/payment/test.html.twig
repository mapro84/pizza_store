{% extends 'base.html.twig' %}

{% block title %}Paiement Test - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="mb-4 text-center">
                <i class="bi bi-credit-card text-danger"></i> Paiement sécurisé (Test)
            </h1>
            
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Mode test:</strong> Utilisez les numéros de carte ci-dessous pour tester.
                Aucun paiement réel ne sera effectué.
            </div>

            {% if app.session.get('payment_success') %}
                <div class="alert alert-success text-center py-5">
                    <i class="bi bi-check-circle-fill fs-1 text-success"></i>
                    <h2 class="mt-3">Paiement accepté !</h2>
                    <p class="lead">Numéro de commande: <strong>{{ app.session.get('payment_order_number') }}</strong></p>
                    <p class="text-muted">Votre pizza sera prête dans 15-20 minutes</p>
                    <a href="{{ path('app_homepage') }}" class="btn btn-danger btn-lg mt-3">
                        <i class="bi bi-house"></i> Retour à l'accueil
                    </a>
                </div>
            {% else %}
                {% if app.session.get('payment_error') %}
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-octagon"></i> {{ app.session.get('payment_error') }}
                </div>
                {% endif %}

                <div class="card">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0"><i class="bi bi-lock"></i> Informations de paiement</h5>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <h3>Total à payer: <span class="text-danger">{{ total|number_format(2, ',', ' ') }} €</span></h3>
                        </div>

                        <form method="POST" action="{{ path('app_payment_test') }}">
                            <div class="mb-3">
                                <label for="card_number" class="form-label">Numéro de carte</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" id="card_number" name="card_number" 
                                           placeholder="4242 4242 4242 4242" maxlength="19" required>
                                    <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="expiry" class="form-label">Date d'expiration</label>
                                    <input type="text" class="form-control" id="expiry" name="expiry" 
                                           placeholder="MM/YY" maxlength="5" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="cvv" class="form-label">CVV</label>
                                    <input type="text" class="form-control" id="cvv" name="cvv" 
                                           placeholder="123" maxlength="4" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="card_name" class="form-label">Nom sur la carte</label>
                                <input type="text" class="form-control" id="card_name" name="card_name" 
                                       placeholder="Jean Dupont" required>
                            </div>

                            <button type="submit" class="btn btn-danger btn-lg w-100">
                                <i class="bi bi-lock"></i> Payer {{ total|number_format(2, ',', ' ') }} €
                            </button>
                        </form>
                    </div>
                </div>

                <div class="card mt-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Cartes de test disponibles</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Cliquez sur une carte pour copier le numéro</p>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Numéro de carte</th>
                                        <th>Type</th>
                                        <th>Résultat</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code class="test-card" data-card="4242424242424242">4242 4242 4242 4242</code></td>
                                        <td><i class="bi bi-credit-card-2-front"></i> Visa</td>
                                        <td><span class="badge bg-success">Succès</span></td>
                                    </tr>
                                    <tr>
                                        <td><code class="test-card" data-card="5555555555554444">5555 5555 5555 4444</code></td>
                                        <td><i class="bi bi-credit-card-2-front"></i> Mastercard</td>
                                        <td><span class="badge bg-success">Succès</span></td>
                                    </tr>
                                    <tr>
                                        <td><code class="test-card" data-card="378282246310005">3782 822463 10005</code></td>
                                        <td><i class="bi bi-credit-card-2-front"></i> Amex</td>
                                        <td><span class="badge bg-success">Succès</span></td>
                                    </tr>
                                    <tr>
                                        <td><code class="test-card" data-card="4000000000000002">4000 0000 0000 0002</code></td>
                                        <td><i class="bi bi-credit-card-2-front"></i> Visa</td>
                                        <td><span class="badge bg-danger">Refusée</span></td>
                                    </tr>
                                    <tr>
                                        <td><code class="test-card" data-card="4000000000009995">4000 0000 0000 9995</code></td>
                                        <td><i class="bi bi-credit-card-2-front"></i> Visa</td>
                                        <td><span class="badge bg-warning">Fonds insuffisants</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="small text-muted mt-3">
                            <strong>CVV:</strong> Utilisez n'importe quel CVV à 3 chiffres (ex: 123)<br>
                            <strong>Date:</strong> Utilisez n'importe quelle date future (ex: 12/28)
                        </p>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <a href="{{ path('app_checkout') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Retour au checkout
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{% block javascripts %}
<script>
document.querySelectorAll('.test-card').forEach(function(el) {
    el.style.cursor = 'pointer';
    el.addEventListener('click', function() {
        var cardNumber = this.getAttribute('data-card');
        var formatted = cardNumber.replace(/(.{4})/g, '$1 ').trim();
        document.getElementById('card_number').value = formatted;
        navigator.clipboard.writeText(cardNumber);
        
        var original = this.innerHTML;
        this.innerHTML = '<i class="bi bi-check"></i> Copié!';
        setTimeout(() => this.innerHTML = original, 1500);
    });
});

document.getElementById('card_number').addEventListener('input', function(e) {
    var value = e.target.value.replace(/\s/g, '').replace(/\D/g, '');
    var formatted = value.match(/.{1,4}/g)?.join(' ') || '';
    e.target.value = formatted;
});

document.getElementById('expiry').addEventListener('input', function(e) {
    var value = e.target.value.replace(/\D/g, '');
    if (value.length >= 2) {
        value = value.substring(0, 2) + '/' + value.substring(2, 4);
    }
    e.target.value = value;
});
</script>
{% endblock %}

<style>
code.test-card {
    background: #f8f9fa;
    padding: 5px 10px;
    border-radius: 4px;
    border: 1px solid #dee2e6;
    transition: all 0.2s;
}
code.test-card:hover {
    background: #e9ecef;
    border-color: #dc3545;
}
</style>
{% endblock %}
