{% extends 'base.html.twig' %}

{% block title %}Nouvel ingrédient - Bella Napoli Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-plus-circle"></i> Nouvel ingrédient</h1>
        <a href="{{ path('app_admin_ingredient_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="POST">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label for="name" class="form-label">Nom *</label>
                            <input type="text" class="form-control" id="name" name="name" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label for="price" class="form-label">Prix (€) *</label>
                            <input type="number" step="0.01" class="form-control" id="price" name="price" required>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label for="position" class="form-label">Position</label>
                            <input type="number" class="form-control" id="position" name="position" value="0">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label for="allergen_type" class="form-label">Type d'allergène</label>
                            <select class="form-select" id="allergen_type" name="allergen_type">
                                <option value="">Aucun</option>
                                <option value="lait">Lait</option>
                                <option value="gluten">Gluten</option>
                                <option value="oeuf">Oeuf</option>
                                <option value="arachide">Arachide</option>
                                <option value="fruits_coquille">Fruits à coquille</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="is_allergen" name="is_allergen">
                    <label class="form-check-label" for="is_allergen">
                        Cet ingrédient est un allergène
                    </label>
                </div>

                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-check-circle"></i> Enregistrer
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
