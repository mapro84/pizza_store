{% extends 'base.html.twig' %}

{% block title %}Ingrédients - Bella Napoli Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-carrot"></i> Gestion des ingrédients</h1>
        <div>
            <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
            <a href="{{ path('app_admin_ingredient_new') }}" class="btn btn-danger">
                <i class="bi bi-plus-circle"></i> Ajouter
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="card">
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prix</th>
                        <th>Allergène</th>
                        <th>Type allergène</th>
                        <th>Position</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ingredient in ingredients %}
                    <tr>
                        <td>{{ ingredient.id }}</td>
                        <td><strong>{{ ingredient.name }}</strong></td>
                        <td>{{ ingredient.formattedPrice }}</td>
                        <td>
                            {% if ingredient.isAllergen %}
                                <span class="badge bg-warning">Oui</span>
                            {% else %}
                                <span class="badge bg-secondary">Non</span>
                            {% endif %}
                        </td>
                        <td>{{ ingredient.allergenType ?: '-' }}</td>
                        <td>{{ ingredient.position }}</td>
                        <td>
                            <a href="{{ path('app_admin_ingredient_edit', {id: ingredient.id}) }}" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="{{ path('app_admin_ingredient_delete', {id: ingredient.id}) }}" 
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Supprimer cet ingrédient ?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
