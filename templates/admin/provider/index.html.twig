{% extends 'base.html.twig' %}

{% block title %}Fournisseurs - Bella Napoli Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-truck"></i> Gestion des fournisseurs</h1>
        <div>
            <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
            <a href="{{ path('app_admin_provider_new') }}" class="btn btn-danger">
                <i class="bi bi-plus-circle"></i> Ajouter
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="card">
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Type</th>
                        <th>Contact</th>
                        <th>Email</th>
                        <th>Téléphone</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for provider in providers %}
                    <tr>
                        <td><strong>{{ provider.name }}</strong></td>
                        <td>
                            <span class="badge bg-info">
                                {% if provider.type == 'ingredient' %}Ingrédients
                                {% elseif provider.type == 'material' %}Matériaux
                                {% else %}Les deux{% endif %}
                            </span>
                        </td>
                        <td>{{ provider.contactName ?: '-' }}</td>
                        <td>{{ provider.email ?: '-' }}</td>
                        <td>{{ provider.phone ?: '-' }}</td>
                        <td>
                            {% if provider.isActive %}
                                <span class="badge bg-success">Actif</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactif</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_admin_provider_edit', {id: provider.id}) }}" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="{{ path('app_admin_provider_delete', {id: provider.id}) }}" 
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Supprimer ce fournisseur ?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
