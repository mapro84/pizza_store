{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.users'|trans }} - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">{{ 'admin.dashboard'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ 'admin.users'|trans }}</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-people me-2"></i>{{ 'admin.users'|trans }}</h1>
    </div>

    <div class="card shadow">
        <div class="card-body">
            {% for flash in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle me-2"></i>{{ flash }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endfor %}
            
            {% for flash in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle me-2"></i>{{ flash }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endfor %}

            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>{{ 'user.username'|trans }}</th>
                            <th>{{ 'user.email'|trans }}</th>
                            <th>{{ 'user.name'|trans }}</th>
                            <th>{{ 'user.roles'|trans }}</th>
                            <th>{{ 'user.created_at'|trans }}</th>
                            <th class="text-center">{{ 'user.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                        <tr>
                            <td>
                                <strong>{{ user.username }}</strong>
                            </td>
                            <td>{{ user.email }}</td>
                            <td>{{ user.firstName|default('') }} {{ user.lastName|default('') }}</td>
                            <td>
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge bg-danger">{{ 'user.role_admin'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ 'user.role_user'|trans }}</span>
                                    {% endif %}
                                {% endfor %}
                            </td>
                            <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                            <td class="text-center">
                                <a href="{{ path('app_admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'user.edit'|trans }}">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="{{ path('app_admin_user_password', {id: user.id}) }}" class="btn btn-sm btn-outline-warning" title="{{ 'user.change_password'|trans }}">
                                    <i class="bi bi-key"></i>
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                {{ 'user.no_users'|trans }}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
