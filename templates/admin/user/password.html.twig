{% extends 'base.html.twig' %}

{% block title %}{{ 'user.change_password'|trans }} - {{ user.username }} - Bella Napoli{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">{{ 'admin.dashboard'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_admin_user_index') }}">{{ 'admin.users'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ 'user.change_password'|trans }} - {{ user.username }}</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-key me-2"></i>{{ 'user.change_password'|trans }}</h4>
                    <p class="mb-0 mt-2"><strong>{{ user.username }}</strong> ({{ user.email }})</p>
                </div>
                <div class="card-body">
                    {% for flash in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle me-2"></i>{{ flash }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {% endfor %}
                    
                    {% for flash in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-triangle me-2"></i>{{ flash|trans }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {% endfor %}

                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle me-2"></i><strong>{{ 'password.requirements'|trans }}</strong>
                        <ul class="mb-0 mt-2">
                            <li>{{ 'password.requirement.min_length'|trans({'%count%': 8}) }}</li>
                            <li>{{ 'password.requirement.uppercase'|trans }}</li>
                            <li>{{ 'password.requirement.number'|trans }}</li>
                            <li>{{ 'password.requirement.special'|trans }}</li>
                        </ul>
                    </div>

                    <form method="post">
                        <div class="mb-3">
                            <label for="new_password" class="form-label">{{ 'user.new_password'|trans }}</label>
                            <input type="password" class="form-control" id="new_password" name="new_password" 
                                   minlength="8" required>
                        </div>

                        <div class="mb-4">
                            <label for="confirm_password" class="form-label">{{ 'user.confirm_password'|trans }}</label>
                            <input type="password" class="form-control" id="confirm_password" name="confirm_password" 
                                   minlength="8" required>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_admin_user_index') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>{{ 'user.cancel'|trans }}
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-lg me-2"></i>{{ 'user.save_password'|trans }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
