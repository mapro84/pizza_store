{% extends 'base.html.twig' %}

{% block title %}Nouvelle commande - Bella Napoli Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-plus-circle"></i> Nouvelle commande fournisseur</h1>
        <a href="{{ path('app_admin_provider_order_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="POST" id="orderForm">
                <div class="mb-3">
                    <label for="provider_id" class="form-label">Fournisseur *</label>
                    <select class="form-select" id="provider_id" name="provider_id" required>
                        <option value="">-- Choisir un fournisseur --</option>
                        {% for provider in providers %}
                        <option value="{{ provider.id }}">{{ provider.name }} ({{ provider.type }})</option>
                        {% endfor %}
                    </select>
                </div>

                <h5 class="mt-4 mb-3">Articles à commander</h5>
                <div id="itemsContainer">
                    <div class="row g-3 item-row mb-3">
                        <div class="col-md-4">
                            <input type="text" class="form-control" name="items[0][name]" placeholder="Nom de l'article" required>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select" name="items[0][type]">
                                <option value="ingredient">Ingrédient</option>
                                <option value="material">Matériau</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <input type="number" step="0.01" class="form-control" name="items[0][price]" placeholder="Prix unitaire" required>
                        </div>
                        <div class="col-md-2">
                            <input type="number" step="0.01" class="form-control" name="items[0][quantity]" placeholder="Quantité" value="1" required>
                        </div>
                        <div class="col-md-1">
                            <input type="text" class="form-control" name="items[0][unit]" placeholder="Unité" value="kg">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-danger btn-sm" onclick="removeItem(this)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn btn-outline-primary mb-3" onclick="addItem()">
                    <i class="bi bi-plus-circle"></i> Ajouter un article
                </button>

                <div class="mb-3">
                    <label for="notes" class="form-label">Notes</label>
                    <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Notes ou instructions spéciales..."></textarea>
                </div>

                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-check-circle"></i> Créer la commande
                </button>
            </form>
        </div>
    </div>
</div>

<script>
let itemCount = 1;

function addItem() {
    const container = document.getElementById('itemsContainer');
    const newRow = document.createElement('div');
    newRow.className = 'row g-3 item-row mb-3';
    newRow.innerHTML = `
        <div class="col-md-4">
            <input type="text" class="form-control" name="items[${itemCount}][name]" placeholder="Nom de l'article" required>
        </div>
        <div class="col-md-2">
            <select class="form-select" name="items[${itemCount}][type]">
                <option value="ingredient">Ingrédient</option>
                <option value="material">Matériau</option>
            </select>
        </div>
        <div class="col-md-2">
            <input type="number" step="0.01" class="form-control" name="items[${itemCount}][price]" placeholder="Prix unitaire" required>
        </div>
        <div class="col-md-2">
            <input type="number" step="0.01" class="form-control" name="items[${itemCount}][quantity]" placeholder="Quantité" value="1" required>
        </div>
        <div class="col-md-1">
            <input type="text" class="form-control" name="items[${itemCount}][unit]" placeholder="Unité" value="kg">
        </div>
        <div class="col-md-1">
            <button type="button" class="btn btn-danger btn-sm" onclick="removeItem(this)">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    `;
    container.appendChild(newRow);
    itemCount++;
}

function removeItem(btn) {
    const rows = document.querySelectorAll('.item-row');
    if (rows.length > 1) {
        btn.closest('.item-row').remove();
    }
}
</script>
{% endblock %}
