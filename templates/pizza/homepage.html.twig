{% extends 'base.html.twig' %}

{% block title %}Bella Napoli - Pizza Artisanale{% endblock %}

{% block body %}
<div class="hero-section">
    <div class="hero-content">
        <h1>Bienvenue chez Bella Napoli</h1>
        <p>Découvrez nos pizzas artisanales préparées avec amour</p>
        <a href="{{ path('app_pizza_index') }}" class="btn btn-danger btn-lg">Voir le menu</a>
    </div>
</div>

<section class="about-section py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 class="mb-4">Une pizzeria familiale de qualité</h2>
                <p class="lead text-muted">
                    Depuis des générations, la famille Romano perpétue la tradition napolitaine 
                    pour vous offrir des pizzas d'exception.
                </p>
                <div class="features-list mt-4">
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-geo-alt-fill text-danger me-3 fs-4"></i>
                        <div>
                            <h5 class="mb-1">Ingrédients locaux</h5>
                            <p class="text-muted mb-0">Nous sélectionnons nos produits auprès de producteurs locaux de la région Varoise.</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-award-fill text-danger me-3 fs-4"></i>
                        <div>
                            <h5 class="mb-1">Qualité premium</h5>
                            <p class="text-muted mb-0">Farines italiennes, mozzarella di bufala, sauces maison : rien n'est laissé au hasard.</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start">
                        <i class="bi bi-people-fill text-danger me-3 fs-4"></i>
                        <div>
                            <h5 class="mb-1">Esprit familial</h5>
                            <p class="text-muted mb-0">Une équipe passionnée qui vous accueille avec le sourire, comme à la maison.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1579751626657-72bc17010498?w=600" 
                     class="img-fluid rounded shadow" alt="Pizza artisanale">
            </div>
        </div>
    </div>
</section>

<div class="features-section">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-heart-fill"></i>
                    <h3>Fait maison</h3>
                    <p>Pâtes fraîches et sauces faites maison chaque jour</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-lightning-fill"></i>
                    <h3>Livraison rapide</h3>
                    <p>Votre pizza livrée chaude en 30 minutes</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-star-fill"></i>
                    <h3>Ingrédients frais</h3>
                    <p>Nous sélectionnons les meilleurs produits locaux</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="featured-pizzas">
    <div class="container">
        <h2 class="text-center mb-4">Nos pizzas populaires</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=400" class="card-img-top" alt="Margherita">
                    <div class="card-body">
                        <h5 class="card-title">Margherita</h5>
                        <p class="text-muted">Sauce tomate, mozzarella, basilic frais</p>
                        <p class="price">10,90 €</p>
                        <div class="d-flex gap-2">
                            <form method="POST" action="{{ path('app_cart_add', {id: 1}) }}" class="flex-grow-1">
                                <input type="hidden" name="size" value="moyenne">
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-cart-plus"></i> Ajouter
                                </button>
                            </form>
                            <a href="{{ path('app_pizza_show', {id: 1}) }}" class="btn btn-outline-danger">
                                <i class="bi bi-info-circle"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1628840042765-356cda07504e?w=400" class="card-img-top" alt="Pepperoni">
                    <div class="card-body">
                        <h5 class="card-title">Pepperoni</h5>
                        <p class="text-muted">Sauce tomate, mozzarella, pepperoni épicé</p>
                        <p class="price">12,90 €</p>
                        <div class="d-flex gap-2">
                            <form method="POST" action="{{ path('app_cart_add', {id: 2}) }}" class="flex-grow-1">
                                <input type="hidden" name="size" value="moyenne">
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-cart-plus"></i> Ajouter
                                </button>
                            </form>
                            <a href="{{ path('app_pizza_show', {id: 2}) }}" class="btn btn-outline-danger">
                                <i class="bi bi-info-circle"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=400" class="card-img-top" alt="Quattro Formaggi">
                    <div class="card-body">
                        <h5 class="card-title">Quattro Formaggi</h5>
                        <p class="text-muted">Mozzarella, gorgonzola, parmesan, taleggio</p>
                        <p class="price">14,90 €</p>
                        <div class="d-flex gap-2">
                            <form method="POST" action="{{ path('app_cart_add', {id: 3}) }}" class="flex-grow-1">
                                <input type="hidden" name="size" value="moyenne">
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-cart-plus"></i> Ajouter
                                </button>
                            </form>
                            <a href="{{ path('app_pizza_show', {id: 3}) }}" class="btn btn-outline-danger">
                                <i class="bi bi-info-circle"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.hero-section {
    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1513104890138-7c749659a591?w=1200');
    background-size: cover;
    background-position: center;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
}
.hero-content h1 { font-size: 3rem; margin-bottom: 1rem; }
.hero-content p { font-size: 1.5rem; margin-bottom: 2rem; }
.feature-card { text-align: center; padding: 2rem; }
.feature-card i { font-size: 3rem; color: #dc3545; margin-bottom: 1rem; }
.featured-pizzas { padding: 4rem 0; }
.card-img-top { height: 200px; object-fit: cover; }
.price { color: #dc3545; font-weight: bold; font-size: 1.25rem; }
</style>
{% endblock %}
